{
  "crons": [
    {
      "path": "/api/cron/follow-ups",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "premerealestate.com" }],
      "destination": "https://www.premerealestate.com/:path",
      "permanent": true
    }
  ]
}
